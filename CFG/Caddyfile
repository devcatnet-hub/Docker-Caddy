# Archivo: Caddyfile
{
    # Admin API (solo local)
    admin localhost:2019
    
    # Logs
    log {
        output file /var/log/caddy/access.log
        level INFO
    }
}

# Puerto 80 - HTTP
:80 {
    # Root directory para archivos estáticos
    root * /APP/HTML
    
    # Logs
    log {
        output file /var/log/caddy/access.log
    }
    
    # Compresión
    encode gzip zstd
    
    # Archivos estáticos
    file_server browse
    
    # PHP-FPM (preparado, comentado hasta que instales PHP)
    # php_fastcgi localhost:9000
    
    # Seguridad básica
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}

